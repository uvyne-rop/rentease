# Backend Environment Variables (.env)
# Copy this file to .env and fill in the values

# Flask Configuration
SECRET_KEY=your-secure-random-key-here-at-least-32-chars

# Frontend URL (for CORS)
# Set this in Railway environment variables
FRONTEND_URL=https://your-app.vercel.app

# Database (optional - for production)
# DATABASE_URL=postgresql://user:password@host:port/dbname
# DB_PATH=/tmp/rentease.db   # optional local fallback when DATABASE_URL is not set

# Admin bootstrap user
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-admin-password

# Email Configuration (optional - for sending emails)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# External storage (optional)
# Supabase Storage (free tier):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_KEY=your-service-role-key
# SUPABASE_BUCKET=uploads

# Or Cloudinary (free tier):
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Deployment Platform
# Used by Flask to determine environment
ENVIRONMENT=production
